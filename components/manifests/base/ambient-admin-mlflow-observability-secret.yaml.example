# Example: platform-wide MLflow tracing credentials for the operator to copy into session namespaces.
# Apply to the operator namespace (same pattern as ambient-admin-langfuse-secret).
#
# This secret should only contain MLflow *credentials* (token, auth method, workspace).
# MLFLOW_TRACKING_URI and MLFLOW_EXPERIMENT_NAME are now set as environment variables on the
# control-plane deployment, not in this secret. See the control-plane-env-patch overlay.
#
#   kubectl create secret generic ambient-admin-mlflow-observability-secret -n <operator-ns> \
#     --from-literal=MLFLOW_TRACKING_TOKEN=<your-mlflow-token> \
#     --from-literal=MLFLOW_TRACKING_AUTH=kubernetes-namespaced \
#     --from-literal=MLFLOW_WORKSPACE=my-workspace
#
# Keys:
#   MLFLOW_TRACKING_TOKEN   - auth token for MLflow server (set as provider credential on the gateway)
#   MLFLOW_TRACKING_AUTH    - auth method; use "kubernetes-namespaced" for MLflow 3.11+ on K8s
#                             so MLflow sends Authorization (service account JWT) and X-MLFLOW-WORKSPACE
#   MLFLOW_WORKSPACE        - optional; fixed workspace id for X-MLFLOW-WORKSPACE instead of pod namespace
#
# The following are now control-plane deployment env vars (NOT secret fields):
#   MLFLOW_TRACKING_URI     - set on CP deployment, forwarded to sandboxes with an MLflow provider
#   MLFLOW_EXPERIMENT_NAME  - set on CP deployment, forwarded to sandboxes with an MLflow provider
apiVersion: v1
kind: Secret
metadata:
  name: ambient-admin-mlflow-observability-secret
  namespace: CHANGE_ME_OPERATOR_NAMESPACE
type: Opaque
stringData:
  MLFLOW_TRACKING_TOKEN: "CHANGE_ME"
  MLFLOW_TRACKING_AUTH: "kubernetes-namespaced"
