# Example: MLflow tracing credentials materialized by Vault/OpenShell.
# This file documents the expected shape only. Production Vault YAMLs are kept
# outside this GitHub repository and materialize this secret into the runner
# environment through OpenShell.
#
# This secret should only contain MLflow credentials. MLFLOW_TRACKING_URI and
# MLFLOW_EXPERIMENT_NAME are control-plane deployment env vars, not secret keys.
# The token is used only for projects or agents with an explicit mlflow
# credential binding.
#
#   kubectl create secret generic mlflow -n <operator-ns> \
#     --from-literal=MLFLOW_TRACKING_TOKEN=<your-mlflow-token>
#
# Keys:
#   MLFLOW_TRACKING_TOKEN   - auth token for MLflow server (set as provider credential on the gateway)
#
# Configure MLFLOW_WORKSPACE / MLFLOW_TRACKING_AUTH as control-plane deployment
# environment variables, not as keys in this credential secret.
#
# For an admin-issued bearer token, omit MLFLOW_TRACKING_AUTH.
apiVersion: v1
kind: Secret
metadata:
  name: mlflow
  namespace: CHANGE_ME_OPERATOR_NAMESPACE
type: Opaque
stringData:
  MLFLOW_TRACKING_TOKEN: "CHANGE_ME"
