{
  "manifest_version": 3,
  "name": "ACP Session Manager",
  "short_name": "ACP Sessions",
  "version": "0.1.0",
  "key": "",
  "description": "Manage Agent Control Plane sessions and chats from a Chrome side panel.",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "Open ACP Sessions"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ]
}
